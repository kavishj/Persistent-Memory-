# Copy this file to `.env` and fill in your values.
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)
#
# Docker stack (Postgres, Weaviate, Redis) starts with:
#   docker compose up postgres weaviate redis -d
#
# Embeddings use sentence-transformers/all-MiniLM-L6-v2 (local, no key needed).
# Only GROQ_API_KEY is strictly required to run the full pipeline.

# ── Database ────────────────────────────────────────────────────────────────
# Sync only (psycopg2) — used by api/, workers/, scripts/seed_schema.py
DATABASE_URL=postgresql://memory:memory@localhost:5432/memory_engine

# ── Weaviate ────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_PORT=50051

# ── Redis / Celery ──────────────────────────────────────────────────────────
# Used as both Celery broker and result backend in workers/tasks.py
REDIS_URL=redis://localhost:6379/0

# ── Groq (extraction primary — required) ────────────────────────────────────
# Primary LLM for extractor, classifier, summarizer.
# Free tier: 14,400 req/day. Get a key at https://console.groq.com/
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Anthropic (extraction fallback — optional) ───────────────────────────────
# Used when Groq is unavailable. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
EXTRACTION_MODEL=claude-haiku-4-5

# ── Google Gemini (extraction second fallback — optional) ────────────────────
# Used when both Groq and Anthropic are unavailable.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# ── Memory engine tuning (optional overrides) ────────────────────────────────
MAX_TOKEN_BUDGET=1500
TOKEN_BUDGET_HARD_CEILING=2000
PROCEDURAL_MIN_SUCCESSES=3
DEDUP_SIMILARITY_THRESHOLD=0.92

# ── Server auth ──────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production_use_a_long_random_string

# ── Agent client (set on the agent side, not the server) ────────────────────
# MEMORY_ENGINE_API_KEY = per-agent key registered in the agents table
# sent as X-API-Key header to the Memory Engine API
MEMORY_ENGINE_API_KEY=your_agent_api_key_here
MEMORY_ENGINE_URL=http://localhost:8000
